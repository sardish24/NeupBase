{
  "version": 2,
  "builds": [
    {
      "src": "api/python/**/*.py",
      "use": "@vercel/python"
    },
    {
      "src": "package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/api/python/(.*)",
      "dest": "/api/python/$1"
    }
  ],
  "crons": [
    {
      "path": "/api/cron",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/cron/daily-study-brief",
      "schedule": "0 7 * * *"
    }
  ]
}
